; Energy minimization
integrator              = steep
emtol                   = 1000.0
emstep                  = 0.01
nsteps                  = 2000
cutoff-scheme           = Verlet
nstlist                 = 10
rlist                   = 1.0
coulombtype             = PME
rcoulomb                = 1.0
rvdw                    = 1.0
pbc                     = xyz
